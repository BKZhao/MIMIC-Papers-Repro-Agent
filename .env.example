# Database: MIMIC-IV PostgreSQL (example)
MIMIC_PG_HOST=localhost
MIMIC_PG_PORT=5432
MIMIC_PG_DB=mimiciv_22
MIMIC_PG_USER=your_user
MIMIC_PG_PASSWORD=your_password
MIMIC_PG_SSLMODE=disable

# Optional: API keys for external research tools
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
SILICONFLOW_API_KEY=

# Optional: clinical skills / services
PYHEALTH_CACHE_DIR=.cache/pyhealth
CLINICALTRIALS_API_BASE=https://clinicaltrials.gov/api/v2

# Optional: default LLM routing for agentic mode
LLM_PROVIDER=siliconflow
LLM_API_KEY_ENV=SILICONFLOW_API_KEY
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_DEFAULT_MODEL=deepseek-ai/DeepSeek-V3
